{
  "name": "quality-buddy",
  "version": "1.0.1",
  "description": "Rotate team members into a Quality Buddy each sprint",
  "private": true,
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --workspace backend run dev",
    "dev:frontend": "npm --workspace frontend run dev",
    "build": "npm --workspace frontend run build",
    "test": "npm --workspace backend test",
    "start": "npm --workspace backend start",
    "aspire:start": "npm --prefix aspire-apphost run aspire:start",
    "aspire:build": "npm --prefix aspire-apphost run aspire:build",
    "aspire:dev": "npm --prefix aspire-apphost run aspire:dev",
    "version": "node scripts/sync-version.js"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  },
  "dependencies": {
    "@posthog/react": "^1.10.3",
    "dotenv": "^17.4.2",
    "posthog-js": "^1.404.1",
    "posthog-node": "^5.45.2"
  }
}
