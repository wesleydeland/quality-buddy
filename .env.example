# Optional environment overrides for docker compose.
# Copy this file to .env and uncomment/edit values you want to change.
# Any value set here takes precedence over the defaults in docker-compose.yml.

# Host port to expose on the Docker host (left side of the port mapping).
# Default: 3001. Change to anything free, e.g. 8080.
# HOST_PORT=3001

# In-container port. Almost never needs to change. If you do change it,
# also update PORT to match. The image's default is 3001.
# PORT=3001

# Container timezone (affects date formatting in the UI).
# TZ=America/Los_Angeles

# PostHog analytics configuration.
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=
# POSTHOG_PROJECT_TOKEN=
# POSTHOG_HOST=
